generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Modulo 1 - Acesso (Login por Loja)
// ==========================================

model Sessao {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token            String    @unique
  lojaCodigo       String    @map("loja_codigo")
  lojaNome         String    @map("loja_nome")
  dispositivoId    String    @map("dispositivo_id")
  criadaEm         DateTime  @default(now()) @map("criada_em") @db.Timestamptz
  ultimaAtividadeEm DateTime @default(now()) @map("ultima_atividade_em") @db.Timestamptz
  revogadaEm       DateTime? @map("revogada_em") @db.Timestamptz

  entregas       Entrega[]

  @@unique([dispositivoId], map: "uq_sessao_dispositivo_ativa")
  @@map("sessoes")
}

// ==========================================
// Modulo 1 - Lojas cadastradas
// ==========================================

model Loja {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo         String  @unique
  nome           String
  ativa          Boolean @default(true)
  adminSenhaHash String? @map("admin_senha_hash")

  @@map("lojas")
}

// ==========================================
// Modulo 4 - Entregadores cadastrados
// ==========================================

model Entregador {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo     String  @unique
  nome       String
  lojaCodigo String  @map("loja_codigo")
  ativo      Boolean @default(true)

  @@index([lojaCodigo, ativo], map: "idx_entregador_loja_ativo")
  @@map("entregadores")
}

// ==========================================
// Tabela unificada de Documentos
// ==========================================

model Documento {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lojaCodigo       String    @map("loja_codigo")
  documentoNumero  String    @map("documento_numero")
  chaveAcesso      String    @map("chave_acesso")
  tipoDocumento    String    @map("tipo_documento") // NFE | NFCE
  clienteNome      String    @map("cliente_nome")
  clienteDocumento String?   @map("cliente_documento")
  valorTotal       Decimal?  @map("valor_total") @db.Decimal(12, 2)
  qtdItens         Int       @map("qtd_itens")
  status           String    @default("pendente") // pendente | em_andamento | parcial | finalizado | cancelado
  payload          Json      // dados completos do Protheus (itens, cliente, etc)
  origem           String    // webhook | consulta
  recebidoEm       DateTime  @default(now()) @map("recebido_em") @db.Timestamptz
  consultadoEm     DateTime? @map("consultado_em") @db.Timestamptz
  removidoEm       DateTime? @map("removido_em") @db.Timestamptz

  @@unique([lojaCodigo, documentoNumero], map: "uq_documento_loja_numero")
  @@index([lojaCodigo, recebidoEm(sort: Desc)], map: "idx_documento_loja_recebido")
  @@map("documentos")
}

// ==========================================
// Modulo 4 e 5 - Execucao e Finalizacao
// ==========================================

model Entrega {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessaoId          String    @map("sessao_id") @db.Uuid
  documentoNumero   String    @map("documento_numero")
  entregadorCodigo  String    @map("entregador_codigo")
  entregadorNome    String    @map("entregador_nome")
  status            String    @default("em_andamento") // em_andamento | finalizada_total | finalizada_parcial | cancelada
  motivoPendencia   String?   @map("motivo_pendencia") // retirada_futura | entrega_futura
  entregaAnteriorId String?   @map("entrega_anterior_id") @db.Uuid
  iniciadaEm        DateTime  @default(now()) @map("iniciada_em") @db.Timestamptz
  finalizadaEm      DateTime? @map("finalizada_em") @db.Timestamptz

  sessao          Sessao         @relation(fields: [sessaoId], references: [id])
  entregaAnterior Entrega?       @relation("Reentrega", fields: [entregaAnteriorId], references: [id])
  reentregas      Entrega[]      @relation("Reentrega")
  itens           EntregaItem[]
  logsAlteracao   LogAlteracao[]

  @@index([documentoNumero, status], map: "idx_entrega_documento_status")
  @@map("entregas")
}

model EntregaItem {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entregaId      String  @map("entrega_id") @db.Uuid
  itemIdProtheus String  @map("item_id_protheus")
  descricao      String
  qtdTotal       Decimal @map("qtd_total") @db.Decimal(12, 3)
  qtdEntregue    Decimal @default(0) @map("qtd_entregue") @db.Decimal(12, 3)
  unidade        String  @default("UN")
  observacao     String?

  entrega Entrega @relation(fields: [entregaId], references: [id], onDelete: Cascade)

  @@map("entregas_itens")
}

// ==========================================
// Modulo 8 - Administrativo
// ==========================================

model AdminSessao {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token      String    @unique
  lojaCodigo String    @map("loja_codigo")
  criadaEm   DateTime  @default(now()) @map("criada_em") @db.Timestamptz
  revogadaEm DateTime? @map("revogada_em") @db.Timestamptz

  @@map("admin_sessoes")
}

model LogAlteracao {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioAdmin  String   @map("usuario_admin")
  ipOrigem      String   @map("ip_origem")
  userAgent     String   @map("user_agent")
  acao          String
  recursoTipo   String   @map("recurso_tipo")
  recursoId     String   @map("recurso_id") @db.Uuid
  dadosAntes    Json     @map("dados_antes")
  dadosDepois   Json     @map("dados_depois")
  motivo        String
  realizadaEm   DateTime @default(now()) @map("realizada_em") @db.Timestamptz

  entrega Entrega? @relation(fields: [recursoId], references: [id])

  @@index([recursoTipo, recursoId, realizadaEm(sort: Desc)], map: "idx_log_recurso")
  @@index([usuarioAdmin, realizadaEm(sort: Desc)], map: "idx_log_usuario")
  @@map("logs_alteracao")
}
