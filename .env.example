# Servidor
PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5173

# Banco
DATABASE_URL=postgresql://app:app@localhost:5432/entregas?schema=public

# Protheus
PROTHEUS_BASE_URL=https://protheus.exemplo.com.br/rest
PROTHEUS_USER=changeme
PROTHEUS_PASSWORD=changeme
PROTHEUS_TIMEOUT_MS=8000
PROTHEUS_MAX_RETRIES=3
PROTHEUS_CB_THRESHOLD=5
PROTHEUS_CB_WINDOW_MS=30000
PROTHEUS_MOCK_ENABLED=true

# Sessao
SESSAO_EXPIRACAO_DIAS=90
